# Discord
DISCORD_TOKEN=your_discord_bot_token
BOT_OWNER_IDS=your_user_id

# Database (PostgreSQL)
DATABASE_URL=postgresql://syne:password@localhost:5432/syne_bot?connection_limit=20&pool_timeout=10

# Redis (Required for production/sharding)
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
